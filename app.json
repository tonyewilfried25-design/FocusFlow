{
  "expo": {
    "name": "FocusFlow",
    "slug": "FocusFlow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tonye.focusflow",
      "permissions": [
        "PACKAGE_USAGE_STATS",
        "SYSTEM_ALERT_WINDOW",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "extra": {
      "eas": {
        "projectId": "3544654f-9919-4c1f-990c-eea818c29056"
      }
    },
    "owner": "tonye01",
    "plugins": [
      "expo-build-properties"
    ]
  }
}